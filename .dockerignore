# Dependencies — reinstalled inside the image from the lockfile
node_modules
mcp-server/node_modules
**/node_modules

# Build output — regenerated by `next build` in the image
.next
out
build
coverage
*.tsbuildinfo

# Local env / secrets — passed in via EasyPanel env vars & build args,
# never baked into the image
.env
.env*
!.env.local.example
!.env.example

# VCS & CI
.git
.github
.gitignore

# Editor / OS cruft
.DS_Store
.editorconfig
.vscode
.idea

# Docs & meta not needed at runtime
docs
CHANGELOG.md
CONTRIBUTING.md
README.md
LICENSE
AGENTS.md
CLAUDE.md

# The standalone MCP server ships separately, not part of the web image
mcp-server

# Local Docker artifacts
Dockerfile
.dockerignore
